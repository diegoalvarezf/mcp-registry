generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Server {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  longDesc    String?
  repoUrl     String
  npmPackage  String?
  authorName  String
  authorUrl   String?
  license     String   @default("MIT")
  version     String   @default("0.1.0")
  tags        String   // JSON array stored as string
  tools       String   // JSON array of MCP tool names
  clients     String   // JSON array: "claude-code", "cursor", "continue"
  transport   String   @default("stdio") // stdio | sse | http
  stars         Int      @default(0)
  verified      Boolean  @default(false)
  featured      Boolean  @default(false)
  installCmd    String?  // "npx -y @modelcontextprotocol/server-github"
  configJson    String?  // JSON template para claude_desktop_config.json
  envVars       String?  // JSON: [{name, description, required, example}]
  category      String?  // "official" | "community" | "enterprise"
  downloadCount Int      @default(0)
  createdBy     String?  // githubLogin of submitter
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reviews       Review[]
}

model Skill {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String
  type         String   @default("prompt") // "prompt" | "agent"
  content      String   // markdown prompt / system prompt
  tags         String   // JSON array
  authorName   String
  authorUrl    String?
  repoUrl      String?
  verified     Boolean  @default(false)
  featured     Boolean  @default(false)
  published    Boolean  @default(false) // false = private library, true = public registry
  installCount Int      @default(0)
  ownerId      String?
  owner        User?    @relation(fields: [ownerId], references: [id])
  createdBy    String?  // githubLogin
  createdAt    DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  comment   String?
  author    String
  createdAt DateTime @default(now())
}

model User {
  id          String       @id @default(cuid())
  githubId    String       @unique
  githubLogin String       @unique
  name        String
  email       String?
  avatarUrl   String?
  role        String       @default("user") // "user" | "admin"
  createdAt   DateTime     @default(now())
  teamMembers TeamMember[]
  skills      Skill[]
}

model Team {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String?
  inviteToken String       @unique @default(cuid())
  createdAt   DateTime     @default(now())
  members     TeamMember[]
  servers     TeamServer[]
  skills      TeamSkill[]
}

model TeamSkill {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  slug        String   // used as slash command name, e.g. "review-pr"
  type        String   @default("prompt") // "prompt" | "agent"
  description String?
  content     String   // markdown prompt content
  addedAt     DateTime @default(now())

  @@unique([teamId, slug])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("member") // "owner" | "member"
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
}

model TeamServer {
  id         String   @id @default(cuid())
  teamId     String
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  serverSlug String
  notes      String?
  addedAt    DateTime @default(now())

  @@unique([teamId, serverSlug])
}
